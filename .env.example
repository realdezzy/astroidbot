# Database
ASTROIDBOT_DATABASE_URL="postgresql://user:pass@localhost:5432/astroidbot"

# Encryption key for wallet private keys (32 bytes, base64-encoded)
# Generate with: python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
AES_KEY="your-generated-base64-key-here"

# AI Provider configuration
AI_PROVIDER="deepseek"
AI_MODEL="deepseek-v4-pro"
# OPENAI_API_KEY="sk-..."
# GOOGLE_AI_API_KEY="..."
DEEPSEEK_API_KEY="sk-..."

# Stacks network
STACKS_NETWORK="mainnet"
STACKS_API_URL="https://api.hiro.so"

# Bot configuration
POLL_INTERVAL_SECONDS=60
DRY_RUN=true
LOG_LEVEL="info"

# Token filtering (comma-separated contract IDs; empty = all tokens)
ALLOWED_TOKENS=""
BLOCKED_TOKENS=""
DUST_THRESHOLD_USD=0.50

# Telegram (required for auth + bot commands)
# TELEGRAM_WEBHOOK_URL: ngrok or production URL. If set, bot uses webhooks instead of polling.
# TELEGRAM_ADMIN_IDS: comma-separated Telegram user IDs with admin access
TELEGRAM_BOT_TOKEN="1234567890:ABCdefGHIjklMNOpqrsTUVwxyz"
TELEGRAM_WEBHOOK_URL=""
TELEGRAM_ADMIN_IDS="123456789"

# Email (SMTP) for verification and password reset
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="astroidbot@example.com"
SMTP_PASS=""
SMTP_FROM="AstroidBot <astroidbot@example.com>"
BCRYPT_ROUNDS=12

# API Server
PORT=8006
JWT_SECRET="generate-a-random-string-at-least-32-characters-and-replace-this"
JWT_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY_DAYS=30
CORS_ORIGIN="http://localhost:5173"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# VelumX Relayer for gasless swaps
# VELUMX_RELAYER_URL: full API base including /api/v1 path — NOT a frontend proxy path
VELUMX_RELAYER_URL="https://api.velumx.xyz/api/v1"
VELUMX_API_KEY="vx-..."

# RPC redundancy
STACKS_FALLBACK_API_URLS="https://api.testnet.hiro.so,https://stacks-node-api.mainnet.stacks.co"

# KMS Configuration
KMS_PROVIDER="local"
KMS_KEY_ID=""

# Redis Configuration
REDIS_URL="redis://localhost:6379"
